# =============================================================================
# Project Maya Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# Authentication
# =============================================================================

# HuggingFace Token (REQUIRED for model downloads)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# =============================================================================
# Application Settings
# =============================================================================

# Project identification
PROJECT_NAME=maya
VERSION=0.1.0

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (enables verbose logging)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# JSON formatted logs (recommended for production)
LOG_JSON=false

# =============================================================================
# Moshi S2S Configuration
# =============================================================================

# Model selection (female=moshika, male=moshiko)
MOSHI_MODEL_NAME=kyutai/moshika-pytorch-bf16

# Quantization: int8 (recommended), fp16, fp32
MOSHI_QUANTIZATION=int8

# CUDA device
MOSHI_DEVICE=cuda:0

# Run warmup on initialization
MOSHI_WARMUP_ON_INIT=true

# =============================================================================
# Chatterbox TTS Configuration
# =============================================================================

# Voice preset or path to cloned voice WAV
CHATTERBOX_VOICE=default

# Emotion exaggeration (0.1=calm, 1.0=dramatic)
CHATTERBOX_EXAGGERATION=0.6

# CFG weight for pacing control
CHATTERBOX_CFG_WEIGHT=0.5

# CUDA device
CHATTERBOX_DEVICE=cuda:0

# Enable streaming output
CHATTERBOX_ENABLE_STREAMING=true

# =============================================================================
# VAD Configuration
# =============================================================================

# Speech probability threshold
VAD_THRESHOLD=0.5

# Minimum speech duration to trigger processing (ms)
VAD_MIN_SPEECH_DURATION_MS=250

# Minimum silence to end segment (ms)
VAD_MIN_SILENCE_DURATION_MS=300

# Padding around speech (ms)
VAD_SPEECH_PAD_MS=30

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind to
SERVER_HOST=0.0.0.0

# HTTP port for REST API
SERVER_HTTP_PORT=8080

# WebSocket port for audio streaming
SERVER_WS_PORT=8765

# Number of workers (keep at 1 for GPU)
SERVER_WORKERS=1

# =============================================================================
# Session Configuration
# =============================================================================

# Maximum session duration (seconds, buffer before 5-min Moshi limit)
SESSION_MAX_DURATION_SECONDS=270

# Conversation turns to retain
SESSION_CONTEXT_WINDOW_TURNS=20

# Idle timeout (seconds)
SESSION_IDLE_TIMEOUT_SECONDS=60

# Warning before context reset (seconds)
SESSION_CONTEXT_RESET_WARNING_SECONDS=30

# =============================================================================
# Humanization Configuration
# =============================================================================

# Enable filler injection
HUMANIZE_ENABLE_FILLERS=true

# Filler probability (0.0-1.0)
HUMANIZE_FILLER_PROBABILITY=0.3

# Enable natural pauses
HUMANIZE_ENABLE_PAUSES=true

# Enable breath sounds
HUMANIZE_ENABLE_BREATH_SOUNDS=true

# Breath volume (0.0-1.0)
HUMANIZE_BREATH_VOLUME=0.25

# =============================================================================
# Emotion Detection Configuration
# =============================================================================

# Enable emotion detection
EMOTION_ENABLED=true

# Emotion model
EMOTION_MODEL_NAME=r-f/wav2vec-english-speech-emotion-recognition

# Update interval (ms)
EMOTION_UPDATE_INTERVAL_MS=500

# =============================================================================
# GPU Configuration
# =============================================================================

# Which GPU to use (0-indexed)
CUDA_VISIBLE_DEVICES=0

# PyTorch memory allocation config
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
